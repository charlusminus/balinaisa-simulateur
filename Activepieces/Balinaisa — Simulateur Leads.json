                  "settings": {
                    "input": {
                      "photo_base64": "{{step_2['output']['photo_base64']}}",
                      "anthropic_api_key": "",
                      "model": "claude-opus-4-8"
                    },
                    "sampleData": {},
                    "sourceCode": {
                      "code": "export const code = async (inputs) => {\n  // ── Agent déco Balinaisa : \"l'œil de Dominique\" ──────────────────────────\n  // Analyse la photo -> sélectionne le mobilier Balinaisa -> devis -> consigne image.\n  // Modèle vision : Claude (par défaut opus ; passer à un sonnet pour réduire le coût).\n\n  // Catalogue Balinaisa (prix HT). TODO: remplacer par le vrai catalogue + prix de Dominique.\n  const CATALOG = [\n    { id: 'joko',    nom: 'Chaise Joko',    categorie: 'chaise',   prix_ht: 279 },\n    { id: 'aruna',   nom: 'Chaise Aruna',   categorie: 'chaise',   prix_ht: 359 },\n    { id: 'dune',    nom: 'Chaise Dune',    categorie: 'chaise',   prix_ht: 309 },\n    { id: 'nara',    nom: 'Fauteuil Nara',  categorie: 'fauteuil', prix_ht: 319 },\n    { id: 'lisa',    nom: 'Chaise Lisa',    categorie: 'chaise',   prix_ht: 339 },\n    { id: 'sari',    nom: 'Chaise Sari',    categorie: 'chaise',   prix_ht: 299 },\n    { id: 'luma',    nom: 'Fauteuil Luma',  categorie: 'fauteuil', prix_ht: 499 },\n    { id: 'ananda',  nom: 'Fauteuil Ananda',categorie: 'fauteuil', prix_ht: 339 },\n    { id: 'andini',  nom: 'Chaise Andini',  categorie: 'chaise',   prix_ht: 219 },\n    { id: 'padma',   nom: 'Chaise Padma',   categorie: 'chaise',   prix_ht: 299 },\n    { id: 'kinanti', nom: 'Chaise Kinanti', categorie: 'chaise',   prix_ht: 319 },\n    { id: 'indra',   nom: 'Table Indra',    categorie: 'table',    prix_ht: 389 },\n  ];\n\n  const fmt = (n) => (Number(n)||0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';\n  const placeholderImg = 'https://placehold.co/560x360/F2ECE3/B87D4B/png?text=Balinaisa+%E2%80%94+simulation+en+pr%C3%A9paration';\n  const fallback = {\n    image_url: placeholderImg, image_link: placeholderImg,\n    products_label: '', qty: '', total_ht: '', tva: '', total_ttc: '',\n    rationale: '', image_prompt: '', status: 'placeholder_no_ai'\n  };\n\n  const apiKey = (inputs.anthropic_api_key || '').trim();\n  let photo = (inputs.photo_base64 || '').trim();\n  if (!apiKey || !photo) return fallback;\n\n  // data URL -> base64 + media_type\n  let mediaType = 'image/jpeg';\n  const m = photo.match(/^data:(image\\/[a-zA-Z]+);base64,(.*)$/);\n  if (m) { mediaType = m[1]; photo = m[2]; }\n\n  const SYSTEM = [\n    \"Tu es un décorateur d'extérieur d'exception, l'œil artistique de Dominique, dédié EXCLUSIVEMENT au mobilier Balinaisa (teck massif, Bali). Style : français, chic, chaleureux, JAMAIS ostentatoire.\",\n    \"À partir d'une photo d'un espace extérieur, sélectionne dans le catalogue fourni les pièces qui subliment CE lieu précis, en quantités justes.\",\n    \"Priorités : (1) proportion & échelle cohérentes avec la photo, laisser respirer ; (2) formes douces, curation plutôt que set assorti, créer des zones ; (3) matières : teck en fil conducteur, zéro clinquant ; (4) couleurs : 1-2 teintes naturelles dominantes (sable, greige, terracotta, vert olive, brun chaud), la couleur avec parcimonie.\",\n    \"Règles dures : recommande UNIQUEMENT des produits du catalogue ; quantités réalistes selon la surface visible ; l'image finale doit AJOUTER seulement le mobilier Balinaisa sans retoucher le reste (architecture, sol, murs, végétation, lumière, perspective préservés).\",\n    \"Réponds STRICTEMENT en JSON, sans texte autour, au format :\",\n    '{\"analyse\":\"\",\"produits\":[{\"id\":\"\",\"nom\":\"\",\"categorie\":\"\",\"quantite\":0,\"prix_ht_unitaire\":0}],\"rationale\":\"\",\"image_prompt\":\"\"}'\n  ].join('\\n');\n\n  const userText = \"Catalogue Balinaisa (id, nom, categorie, prix_ht):\\n\" + JSON.stringify(CATALOG) +\n    \"\\n\\nAnalyse la photo ci-jointe et propose la sélection Balinaisa idéale. Réponds en JSON strict (français).\";\n\n  try {\n    const resp = await fetch('https://api.anthropic.com/v1/messages', {\n      method: 'POST',\n      headers: { 'x-api-key': apiKey, 'anthropic-version': '2023-06-01', 'content-type': 'application/json' },\n      body: JSON.stringify({\n        model: inputs.model || 'claude-opus-4-8',\n        max_tokens: 1200,\n        system: SYSTEM,\n        messages: [{ role: 'user', content: [\n          { type: 'image', source: { type: 'base64', media_type: mediaType, data: photo } },\n          { type: 'text', text: userText }\n        ]}]\n      })\n    });\n    const data = await resp.json();\n    let txt = (data && data.content && data.content[0] && data.content[0].text) || '';\n    txt = txt.replace(/```json|```/g, '').trim();\n    const start = txt.indexOf('{'), end = txt.lastIndexOf('}');\n    const parsed = JSON.parse(txt.slice(start, end + 1));\n\n    // recalcul du devis côté serveur (source de vérité = catalogue)\n    const byId = Object.fromEntries(CATALOG.map(c => [c.id, c]));\n    let totalHT = 0;\n    const items = (parsed.produits || []).map(pr => {\n      const cat = byId[pr.id];\n      const unit = cat ? cat.prix_ht : (Number(pr.prix_ht_unitaire) || 0);\n      const q = Math.max(1, parseInt(pr.quantite) || 1);\n      totalHT += unit * q;\n      return { nom: (cat ? cat.nom : pr.nom), qty: q };\n    });\n    const tva = totalHT * 0.20, totalTTC = totalHT + tva;\n    const productsLabel = items.map(i => `${i.nom} ×${i.qty}`).join(' + ');\n    const totalQty = items.reduce((s, i) => s + i.qty, 0);\n\n    return {\n      image_url: placeholderImg,      // image finale : à générer par le modèle image via image_prompt\n      image_link: placeholderImg,\n      products_label: productsLabel,\n      qty: totalQty,\n      total_ht: fmt(totalHT),\n      tva: fmt(tva),\n      total_ttc: fmt(totalTTC),\n      rationale: parsed.rationale || '',\n      analyse: parsed.analyse || '',\n      image_prompt: parsed.image_prompt || '',\n      status: 'ai_ok'\n    };\n  } catch (e) {\n    return { ...fallback, status: 'ai_error', error: String(e) };\n  }\n};",
                      "packageJson": "{}"
                    },
