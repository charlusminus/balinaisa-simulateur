                    "displayName": "Générer l'image de simulation (Gemini 2.5 Flash Image)",
                    "settings": {
                      "input": {
                        "photo_base64": "{{step_2['output']['photo_base64']}}",
                        "image_prompt": "{{step_6['output']['image_prompt']}}",
                        "gemini_api_key": "",
                        "model": "gemini-2.5-flash-image"
                      },
                      "sampleData": {},
                      "sourceCode": {
                        "code": "export const code = async (inputs) => {\n  // Édite la photo : ajoute UNIQUEMENT le mobilier Balinaisa, garde le reste intact.\n  const key = (inputs.gemini_api_key || '').trim();\n  let photo = (inputs.photo_base64 || '').trim();\n  const editPrompt = (inputs.image_prompt || '').trim();\n  const out = { generated_base64: '', mime: 'image/png', status: 'skip' };\n  if (!key || !photo || !editPrompt) return out;\n\n  let mime = 'image/jpeg';\n  const m = photo.match(/^data:(image\\/[a-zA-Z]+);base64,(.*)$/);\n  if (m) { mime = m[1]; photo = m[2]; }\n\n  const HARD =\n    \"Édite la photo fournie en y intégrant UNIQUEMENT le mobilier d'extérieur en teck Balinaisa décrit ci-dessous. \" +\n    \"Conserve STRICTEMENT le reste de la scène : architecture, sol, murs, végétation, ciel, lumière, ombres et perspective inchangés. \" +\n    \"Respecte l'échelle et la perspective d'origine. Rendu photoréaliste, haut de gamme, chaleureux, sans ostentation.\\n\\n\";\n\n  const model = inputs.model || 'gemini-2.5-flash-image';\n  try {\n    const resp = await fetch(\n      `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${encodeURIComponent(key)}`,\n      { method: 'POST', headers: { 'content-type': 'application/json' },\n        body: JSON.stringify({\n          contents: [{ parts: [\n            { inline_data: { mime_type: mime, data: photo } },\n            { text: HARD + editPrompt }\n          ]}],\n          generationConfig: { responseModalities: ['IMAGE'] }\n        })\n      });\n    const data = await resp.json();\n    const parts = ((((data.candidates || [])[0] || {}).content) || {}).parts || [];\n    const imgPart = parts.find(p => p.inline_data || p.inlineData);\n    const inline = imgPart && (imgPart.inline_data || imgPart.inlineData);\n    if (inline && inline.data) {\n      return { generated_base64: inline.data, mime: inline.mime_type || inline.mimeType || 'image/png', status: 'ok' };\n    }\n    return { ...out, status: 'no_image', debug: JSON.stringify(data).slice(0, 400) };\n  } catch (e) { return { ...out, status: 'error', error: String(e) }; }\n};",
                        "packageJson": "{}"
                      },
                      "errorHandlingOptions": {
                        "retryOnFailure": {
                          "value": false
                        },
                        "continueOnFailure": {
