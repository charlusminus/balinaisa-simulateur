                    "nextAction": {
                      "name": "step_10",
                      "skip": false,
                      "type": "CODE",
                      "valid": true,
                      "displayName": "Héberger l'image (ImgBB) → URL publique",
                      "settings": {
                        "input": {
                          "generated_base64": "{{step_9['output']['generated_base64']}}",
                          "imgbb_api_key": ""
                        },
                        "sampleData": {},
                        "sourceCode": {
                          "code": "export const code = async (inputs) => {\n  // Héberge l'image générée (base64) sur ImgBB et renvoie une URL publique.\n  const key = (inputs.imgbb_api_key || '').trim();\n  const b64 = (inputs.generated_base64 || '').trim();\n  const placeholder = 'https://placehold.co/560x360/F2ECE3/B87D4B/png?text=Balinaisa+%E2%80%94+simulation';\n  if (!key || !b64) return { image_url: placeholder, hosted: false, status: 'skip' };\n  try {\n    const body = new URLSearchParams();\n    body.append('image', b64);\n    const resp = await fetch(`https://api.imgbb.com/1/upload?key=${encodeURIComponent(key)}`, { method: 'POST', body });\n    const data = await resp.json();\n    const url = data && data.data && (data.data.url || (data.data.image && data.data.image.url));\n    return url ? { image_url: url, hosted: true, status: 'ok' }\n              : { image_url: placeholder, hosted: false, status: 'no_url', debug: JSON.stringify(data).slice(0, 400) };\n  } catch (e) { return { image_url: placeholder, hosted: false, status: 'error', error: String(e) }; }\n};",
