                  "sampleData": {},
                  "sourceCode": {
                    "code": "export const code = async (inputs) => {\n  // Récupère le n° de ligne quelle que soit la forme de sortie d'insert_row\n  const o = inputs.insert_output || {};\n  let row = o.row ?? o.rowId ?? o.rowNumber ?? null;\n  const range = (o.updates && o.updates.updatedRange) || o.updatedRange || '';\n  if (!row && range) {\n    const m = String(range).match(/!\\D*(\\d+)/);\n    if (m) row = parseInt(m[1], 10);\n  }\n  return { row_number: row, found: !!row };\n};",
